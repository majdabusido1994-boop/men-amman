{
  "buildCommand": "cd frontend && npm ci && npx expo export --platform web",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/_expo/(.*)", "destination": "/_expo/$1" },
    { "source": "/static/(.*)", "destination": "/static/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "EXPO_PUBLIC_API_URL": "https://men-amman-api.onrender.com/api"
  }
}
